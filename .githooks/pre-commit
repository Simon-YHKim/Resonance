#!/usr/bin/env bash
# 잔향 pre-commit hook — 잘못된 코드 머지 안전망.
#
# 검증:
#   1. typecheck (tsc --noEmit) — 18~20초, dev flow 허용 가능
#
# 의도적 제외:
#   - test (17초, 두 번 합산 너무 느림 — pre-push 또는 CI에서 보장)
#   - ESLint (현재 미설치 — Phase 1+ 도입 시 추가)
#
# 우회: SKIP_TYPECHECK=1 git commit 또는 --no-verify (긴급 시만)

set -euo pipefail

if [[ "${SKIP_TYPECHECK:-0}" == "1" ]]; then
  echo "[pre-commit] SKIP_TYPECHECK=1 set — skipping typecheck."
  exit 0
fi

# 클라이언트 변경 없으면 스킵
if ! git diff --cached --name-only | grep -qE '^(client/|worker/)'; then
  echo "[pre-commit] no client/ or worker/ changes — skipping typecheck."
  exit 0
fi

echo "[pre-commit] running typecheck..."
if git diff --cached --name-only | grep -q '^client/'; then
  pnpm --filter ./client typecheck
fi
if git diff --cached --name-only | grep -q '^worker/'; then
  pnpm --filter ./worker typecheck
fi
echo "[pre-commit] typecheck passed."
