# pnpm — Expo / React Native 호환
# Metro bundler 가 hoisted node_modules 를 기대하므로 native lib 은 hoist 권장.
# 단 strict workspace boundary 는 유지 (pnpm 기본).
node-linker=hoisted
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*nativewind*
public-hoist-pattern[]=metro
public-hoist-pattern[]=*babel*
