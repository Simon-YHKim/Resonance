{
  "name": "resonance",
  "version": "0.0.1",
  "private": true,
  "description": "잔향(Resonance: Echoes of a Forgotten Self) - LLM-driven GPS text MMORPG",
  "scripts": {
    "dev": "pnpm --filter @resonance/web dev",
    "dev:worker": "pnpm --filter @resonance/worker dev",
    "dev:mobile": "pnpm --filter @resonance/mobile start",
    "build": "pnpm --filter @resonance/web build",
    "build:web": "pnpm --filter @resonance/web build",
    "build:mobile": "pnpm --filter @resonance/mobile export:web",
    "test": "pnpm -r test",
    "test:web": "pnpm --filter @resonance/web test",
    "test:worker": "pnpm --filter @resonance/worker test",
    "test:shared": "pnpm --filter @resonance/shared test",
    "test:coverage": "pnpm --filter @resonance/worker test:coverage",
    "typecheck": "pnpm -r typecheck",
    "typecheck:web": "pnpm --filter @resonance/web typecheck",
    "typecheck:worker": "pnpm --filter @resonance/worker typecheck",
    "typecheck:mobile": "pnpm --filter @resonance/mobile typecheck",
    "typecheck:shared": "pnpm --filter @resonance/shared typecheck"
  },
  "packageManager": "pnpm@10.33.0"
}
